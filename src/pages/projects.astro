---
import Layout from '../layouts/Layout.astro';
import { featuredProjects } from '../data/projects';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const sortedProjects = [...featuredProjects].sort((a, b) => (b.isFlagship ? 1 : -1));

const labs = [
  { title: "Custom CSS Grid Engine", tech: "TypeScript", desc: "A lightweight utility for generating dynamic layouts." },
  { title: "Local LLM Wrapper", tech: "Python", desc: "FastAPI bridge for local LLaMA inference." },
  { title: "Tailwind Component Kit", tech: "Astro", desc: "Internal design system for rapid prototyping." },
];
---

<Layout title="Projects | Jero Halili">
  <main class="pt-32 pb-24 px-4 md:px-10 max-w-[1200px] mx-auto">
    
    <header class="mb-16 space-y-4">
      <h1 class="text-6xl md:text-8xl font-black tracking-tighter uppercase leading-[0.85] dark:text-white italic">
        The Projects<br/> <span class="text-orange-500 underline decoration-zinc-200 dark:border-zinc-800 underline-offset-8">Archive.</span>
      </h1>
      <p class="text-lg text-zinc-700 dark:text-zinc-300 font-medium max-w-2xl leading-relaxed">
        A collection of engineered systems, creative experiments, and full-stack applications.
      </p>
    </header>

    <div class="space-y-6 mb-32">
      {sortedProjects.map((project) => (
        <div class="group relative bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-[2rem] p-6 md:p-10 overflow-hidden transition-all duration-500 hover:border-orange-500/40 shadow-sm">
          
          <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 relative z-10 items-stretch">
            <div class="lg:col-span-7 flex flex-col justify-center items-start space-y-6">
              <div class="space-y-4">
                <div class="flex items-center gap-3">
                  <span class="px-3 py-1 bg-orange-500/10 text-orange-500 rounded-full font-mono text-[9px] font-bold uppercase tracking-widest border border-orange-500/20">{project.tag}</span>
                  {project.isFlagship && <span class="text-[9px] font-normal uppercase text-zinc-400">Main Focus</span>}
                </div>
                <h2 class="text-4xl md:text-5xl font-black tracking-tighter dark:text-white uppercase italic leading-tight">{project.title}</h2>
                <p class="text-base text-zinc-600 dark:text-zinc-300 max-w-xl leading-relaxed">{project.description}</p>
              </div>

              <a href={`${base}/projects/${project.slug}`} class="bg-zinc-900 dark:bg-white text-white dark:text-black px-8 py-3.5 rounded-full font-black uppercase tracking-widest text-[10px] hover:bg-orange-500 hover:text-white transition-all transform active:scale-95 flex items-center gap-3">
                Full Case Study
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
              </a>
            </div>

            <div class="lg:col-span-5 min-h-[240px] flex items-center justify-center bg-zinc-50 dark:bg-zinc-800/30 rounded-[1.5rem] border border-zinc-100 dark:border-zinc-800 overflow-hidden relative">
              <span class="text-8xl font-black italic text-zinc-200 dark:text-zinc-700/10 select-none group-hover:scale-110 group-hover:rotate-3 transition-transform duration-700">{project.id}</span>
              
              <div class="absolute bottom-4 right-4 flex gap-1.5">
                {project.details.tags.slice(0,3).map(tech => (
                   <span class="px-2.5 py-1 bg-white/80 dark:bg-zinc-900/80 backdrop-blur-md rounded-full text-[8px] font-bold uppercase dark:text-zinc-300 border border-zinc-200/50 dark:border-white/5">{tech}</span>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <section class="border-t border-zinc-200 dark:border-zinc-800 pt-16">
      <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-10 gap-4">
        <h2 class="text-3xl font-black uppercase tracking-tighter dark:text-white italic">The Lab</h2>
        <p class="text-zinc-500 text-[10px] uppercase font-bold tracking-widest">Experimental Snippets</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {labs.map(lab => (
          <div class="p-6 bg-zinc-50 dark:bg-zinc-900 rounded-[1.5rem] border border-zinc-200 dark:border-zinc-800 hover:border-orange-500/30 transition-all group">
            <span class="text-[9px] font-mono text-orange-500 font-bold uppercase">{lab.tech}</span>
            <h3 class="text-lg font-bold dark:text-white mt-1 mb-2 uppercase tracking-tight">{lab.title}</h3>
            <p class="text-zinc-600 dark:text-zinc-400 text-[13px] leading-relaxed">{lab.desc}</p>
          </div>
        ))}
      </div>
    </section>
  </main>
</Layout>
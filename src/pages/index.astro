---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Jero Halili | Systems Builder">
  <main class="w-full space-y-12 md:space-y-20 pb-32 transition-colors duration-500">
    
    <section class="w-full pt-32 pb-12 md:pt-40 md:pb-24 px-4 md:px-10">
      <div class="max-w-[1400px] mx-auto grid grid-cols-1 lg:grid-cols-12 gap-6">
        
        <div class="lg:col-span-8 bg-zinc-50 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 p-8 md:p-16 rounded-[2rem] md:rounded-[3rem] flex flex-col justify-center">
          <p class="text-orange-500 font-mono tracking-widest font-bold uppercase text-xs mb-4">
            Computer Scientist · Full-Stack Developer · AI Engineer
          </p>
          <h1 class="text-5xl md:text-7xl xl:text-[90px] font-black tracking-tighter leading-[0.9] text-zinc-900 dark:text-white mb-8 transition-none">
            I BUILD SYSTEMS <br /> THAT <span class="text-orange-500 italic">SCALE & GROW</span>
          </h1>
          <p class="text-zinc-500 dark:text-zinc-400 text-lg md:text-xl max-w-xl leading-relaxed">
            Full-stack developer & AI automation engineer based in Angeles, Philippines.
          </p>
        </div>

        <div class="lg:col-span-4 bg-zinc-100 dark:bg-zinc-900 rounded-[2rem] md:rounded-[3rem] overflow-hidden relative group min-h-[450px] flex flex-col justify-end">
          <div class="absolute inset-0 z-0">
            <img 
              src={`${base}/images/jero-portrait.png`} 
              alt="Jero Halili" 
              class="w-full h-full object-cover object-top transition-transform duration-700 group-hover:scale-105"
            />
          </div>
          <div class="absolute inset-0 z-10 bg-gradient-to-b from-transparent via-transparent to-white/90 dark:to-zinc-950/95 pointer-events-none"></div>
          
          <div class="relative z-20 w-full p-6">
            <div class="bg-white/40 dark:bg-zinc-900/40 backdrop-blur-xl border border-white/20 dark:border-zinc-700/30 p-5 rounded-[1.5rem] md:rounded-[2rem] shadow-2xl">
              <div class="space-y-3">
                <div class="flex justify-between items-center">
                  <p class="text-[10px] uppercase tracking-[0.2em] font-black text-orange-500">Jero Halili</p>
                  <div class="bg-orange-500 p-1.5 rounded-full shadow-lg shadow-orange-500/20">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3"><path d="M7 7l10 10M17 7H7v10"/></svg>
                  </div>
                </div>
                <h3 class="text-lg md:text-xl font-bold tracking-tight text-zinc-900 dark:text-white leading-tight">
                  Turning workflows <span class="italic font-medium text-orange-600">into code.</span>
                </h3>
                <div class="flex items-center gap-2 border-t border-zinc-200/50 dark:border-zinc-700/50 pt-3">
                  <span class="w-1.5 h-1.5 rounded-full bg-orange-500 animate-pulse"></span>
                  <p class="text-xs font-medium text-zinc-600 dark:text-zinc-400">MERN Stack · AI Orchestration</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="lg:col-span-12 grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 mt-6">
          {[
            { label: 'Projects', val: '12+' },
            { label: 'Happy Clients', val: '100%' },
            { label: 'Followers', val: '2.5k' },
            { label: 'Experience', val: '2yrs+' },
            { label: 'Stack', val: 'MERN' }
          ].map((stat) => (
            <div class="bg-zinc-50 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 p-6 rounded-[1.5rem] flex flex-col justify-center items-center text-center group hover:border-orange-500/50 transition-colors">
              <p class="text-[10px] uppercase tracking-widest font-bold text-zinc-400 mb-1">{stat.label}</p>
              <p class="text-2xl font-black text-zinc-900 dark:text-white group-hover:text-orange-500 transition-colors">{stat.val}</p>
            </div>
          ))}

          <a href="/about" class="bg-orange-500 p-6 rounded-[1.5rem] flex flex-col justify-center items-center text-center group hover:bg-zinc-900 dark:hover:bg-white transition-all">
            <p class="text-[10px] uppercase tracking-widest font-bold text-white/80 group-hover:text-zinc-400 mb-1">More info</p>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-white group-hover:text-orange-500 transition-colors"><path d="M7 17l10-10M17 17V7H7"/></svg>
          </a>
        </div>
      </div>
    </section>

    <section class="w-full relative overflow-hidden py-12 border-y border-zinc-100 dark:border-zinc-800 bg-white dark:bg-black transition-colors duration-500">
      <div class="flex overflow-hidden select-none">
        <div class="flex flex-none items-center min-w-full animate-marquee">
          {[ "Full-Stack Systems", "AI Orchestration", "MERN Stack", "Database Architecture", "n8n Automation", "UI/UX Design" ].map((item) => (
            <div class="flex items-center">
              <span class="text-3xl md:text-5xl font-black tracking-tighter text-zinc-900 dark:text-white uppercase italic px-12 md:px-16 transition-none">
                {item}
              </span>
              <span class="w-3 h-3 md:w-4 md:h-4 rounded-full bg-orange-500 shrink-0 shadow-[0_0_15px_rgba(249,115,22,0.4)]"></span>
            </div>
          ))}
        </div>
        <div class="flex flex-none items-center min-w-full animate-marquee" aria-hidden="true">
          {[ "Full-Stack Systems", "AI Orchestration", "MERN Stack", "Database Architecture", "n8n Automation", "UI/UX Design" ].map((item) => (
            <div class="flex items-center">
              <span class="text-3xl md:text-5xl font-black tracking-tighter text-zinc-900 dark:text-white uppercase italic px-12 md:px-16 transition-none">
                {item}
              </span>
              <span class="w-3 h-3 md:w-4 md:h-4 rounded-full bg-orange-500 shrink-0 shadow-[0_0_15px_rgba(249,115,22,0.4)]"></span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="works" class="w-full px-4 md:px-10">
      <div class="max-w-[1400px] mx-auto space-y-8">
        <div class="flex justify-between items-end border-b border-zinc-100 dark:border-zinc-800 pb-6">
          <div class="space-y-1">
            <h2 class="text-4xl md:text-5xl font-black tracking-tighter dark:text-white uppercase">Featured Works</h2>
            <p class="text-zinc-500 dark:text-zinc-400 text-sm font-medium">Engineered solutions for marketing, education, and creative industries.</p>
          </div>
          <a href="/projects" class="text-orange-500 font-bold text-xs uppercase tracking-widest hover:translate-x-1 transition-transform mb-1">All Projects →</a>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          {projects.filter(p => p.data.title.includes("Automated AI Marketing System")).map((project) => (
            <div class="bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-[2rem] p-8 md:p-12 flex flex-col justify-between group hover:border-orange-500/50 transition-all duration-500">
              <div class="space-y-6">
                <div class="flex justify-between items-start">
                  <span class="px-3 py-1 bg-orange-500/10 text-orange-500 rounded-full font-mono text-[10px] font-bold uppercase tracking-widest border border-orange-500/20">Flagship System</span>
                  <span class="text-zinc-300 dark:text-zinc-700 font-black text-xl italic">01</span>
                </div>
                <h3 class="text-4xl md:text-6xl font-black tracking-tighter dark:text-white leading-[0.9]">{project.data.title}</h3>
                <p class="text-zinc-500 dark:text-zinc-400 text-lg leading-relaxed max-w-md">{project.data.description}</p>
              </div>
              <div class="mt-12 bg-zinc-50 dark:bg-zinc-800/50 rounded-[1.5rem] aspect-video flex items-center justify-center overflow-hidden border border-zinc-100 dark:border-zinc-800">
                <span class="text-8xl font-black text-zinc-200 dark:text-zinc-700/20 uppercase tracking-tighter group-hover:scale-110 transition-transform duration-700">
                  {project.data.impact.split(' ')[0]}
                </span>
              </div>
              <div class="pt-8">
                <a href={`/projects/${project.id}`} class="inline-flex items-center gap-4 bg-zinc-900 dark:bg-white text-white dark:text-black px-8 py-4 rounded-full font-bold hover:bg-orange-500 transition-colors">
                  View Architecture
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
                </a>
              </div>
            </div>
          ))}

          <div class="flex flex-col gap-6">
            {[ "School Organization System", "Artist Portfolio Website" ].map((title, index) => (
              projects.filter(p => p.data.title.includes(title)).map((project) => (
                <div class="flex-1 bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-[2rem] p-8 flex flex-col md:flex-row gap-8 group hover:border-orange-500/50 transition-all duration-300">
                  <div class="w-full md:w-40 bg-zinc-50 dark:bg-zinc-800/50 rounded-[1.2rem] aspect-square flex items-center justify-center shrink-0 border border-zinc-100 dark:border-zinc-800">
                    <span class="text-3xl font-black text-zinc-200 dark:text-zinc-700/30 italic">0{index + 2}</span>
                  </div>
                  <div class="flex flex-col justify-center space-y-3">
                    <span class="text-orange-500 font-mono text-[10px] font-bold uppercase tracking-widest">{project.data.subtitle}</span>
                    <h3 class="text-2xl font-bold tracking-tight dark:text-white leading-tight">{project.data.title}</h3>
                    <p class="text-zinc-500 dark:text-zinc-400 text-sm line-clamp-2">{project.data.description}</p>
                    <a href={`/projects/${project.id}`} class="text-xs font-black uppercase tracking-widest dark:text-white hover:text-orange-500 transition-colors pt-2">System Details →</a>
                  </div>
                </div>
              ))
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
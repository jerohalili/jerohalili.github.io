---
import Layout from '../layouts/Layout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

const projects: CollectionEntry<'projects'>[] = await getCollection('projects');
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Jero Halili | Systems Builder">
  <main class="w-full space-y-12 md:space-y-20 pb-32">
    
    <section class="w-full pt-32 pb-12 md:pt-40 md:pb-24 px-4 md:px-10">
      <div class="max-w-[1400px] mx-auto grid grid-cols-1 lg:grid-cols-12 gap-6">
        <div class="lg:col-span-8 bg-zinc-50 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 p-8 md:p-16 rounded-[2rem] md:rounded-[3rem] flex flex-col justify-center">
          <p class="text-orange-500 font-mono tracking-widest font-bold uppercase text-xs mb-4">
            Computer Scientist · Full-Stack Developer · AI Engineer
          </p>
          <h1 class="text-5xl md:text-7xl xl:text-[90px] font-black tracking-tighter leading-[0.9] text-zinc-900 dark:text-white mb-8">
            I BUILD SYSTEMS <br /> THAT <span class="text-orange-500 italic">SCALE & GROW</span>
          </h1>
          <p class="text-zinc-500 dark:text-zinc-400 text-lg md:text-xl max-w-xl leading-relaxed">
            Full-stack developer & AI automation engineer based in Angeles, Philippines.
          </p>
        </div>

        <div class="lg:col-span-4 bg-zinc-100 dark:bg-zinc-900 rounded-[2rem] md:rounded-[3rem] overflow-hidden relative group min-h-[450px] flex flex-col justify-end">
          <div class="absolute inset-0 z-0">
            <img src={`${base}/images/jero-portrait.png`} alt="Jero" class="w-full h-full object-cover object-top" />
          </div>
          <div class="absolute inset-0 z-10 bg-gradient-to-b from-transparent to-zinc-950/95 pointer-events-none"></div>
          <div class="relative z-20 w-full p-6">
            <div class="bg-white/40 dark:bg-zinc-900/40 backdrop-blur-xl border border-white/20 p-5 rounded-[2rem]">
              <p class="text-[10px] uppercase tracking-[0.2em] font-black text-orange-500">Jero Halili</p>
              <h3 class="text-lg font-bold text-white leading-tight mt-2">Turning workflows <span class="italic text-orange-400">into code.</span></h3>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="works" class="w-full px-4 md:px-10">
      <div class="max-w-[1400px] mx-auto space-y-8">
        <h2 class="text-4xl md:text-5xl font-black tracking-tighter dark:text-white uppercase">Featured Works</h2>
        
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          {/* Flagship */}
          {projects.filter((p: CollectionEntry<'projects'>) => p.id === "automated-ai-marketing").map((project: CollectionEntry<'projects'>) => (
            <div class="bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-[2rem] p-8 md:p-12 flex flex-col justify-between group">
              <div>
                <span class="px-3 py-1 bg-orange-500/10 text-orange-500 rounded-full font-mono text-[10px] font-bold uppercase">Flagship System</span>
                <h3 class="text-4xl md:text-6xl font-black tracking-tighter dark:text-white mt-6">{project.data.title}</h3>
                <p class="text-zinc-500 mt-4 text-lg">{project.data.description}</p>
              </div>
              <div class="pt-8">
                <a href={`${base}/projects/${project.id}`} class="inline-flex items-center gap-4 bg-zinc-900 dark:bg-white text-white dark:text-black px-8 py-4 rounded-full text-xs font-black uppercase hover:bg-orange-500 transition-colors">
                  {project.data.buttonText || "View Project"}
                </a>
              </div>
            </div>
          ))}

          {/* Secondary List */}
          <div class="flex flex-col gap-6">
            {projects.filter((p: CollectionEntry<'projects'>) => p.id !== "automated-ai-marketing").map((project: CollectionEntry<'projects'>, index: number) => (
              <div class="bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-[2rem] p-8 flex gap-8">
                <div class="flex flex-col justify-center space-y-4">
                  <h3 class="text-2xl font-bold dark:text-white">{project.data.title}</h3>
                  <a href={`${base}/projects/${project.id}`} class="text-orange-500 font-black text-xs uppercase tracking-widest">View Project →</a>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  // 1. MUST fetch from 'blog' collection, not 'projects'
  const blogEntries = await getCollection('blog');
  
  return blogEntries.map(entry => ({
    // 2. The key MUST be 'slug' to match the filename [slug].astro
    params: { slug: entry.id }, 
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Formatting function for the date
const formatDate = (date: Date) => date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<Layout title={`${entry.data.title} | Jero Halili`}>
  <main class="pt-32 pb-32 px-4 md:px-10 max-w-[800px] mx-auto">
    <a href={`${base}/blogs`} class="text-orange-500 font-bold text-xs uppercase tracking-widest mb-12 inline-block hover:-translate-x-1 transition-transform">
      ← Back to All Posts
    </a>

    <header class="mb-16">
      <div class="flex items-center gap-3 mb-6">
        <span class="px-3 py-1 bg-orange-500/10 text-orange-500 border border-orange-500/20 rounded-full font-mono text-[10px] font-bold uppercase tracking-widest">
          {entry.data.category}
        </span>
        <span class="text-zinc-500 dark:text-zinc-400 font-mono text-[10px] uppercase">
          {formatDate(entry.data.pubDate)} · {entry.data.readTime}
        </span>
      </div>
      
      <h1 class="text-5xl md:text-7xl font-black tracking-tighter leading-tight dark:text-white mb-8 uppercase italic">
        {entry.data.title}
      </h1>
      
      <div class="flex flex-wrap gap-2">
        {entry.data.tags.map(tag => (
          <span class="px-3 py-1 bg-zinc-100 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-full text-[10px] font-bold uppercase tracking-widest text-zinc-500 dark:text-zinc-400">
            {tag}
          </span>
        ))}
      </div>
    </header>

    <article class="prose prose-zinc dark:prose-invert max-w-none 
      prose-h1:text-4xl prose-h1:font-black prose-h1:tracking-tighter prose-h1:uppercase
      prose-h2:text-3xl prose-h2:font-black prose-h2:tracking-tighter prose-h2:uppercase
      prose-h3:text-2xl prose-h3:font-black prose-h3:tracking-tighter prose-h3:uppercase
      prose-p:text-lg prose-p:leading-relaxed prose-p:text-zinc-700 dark:prose-p:text-zinc-300
      prose-strong:text-orange-500
      prose-code:text-orange-500 prose-code:bg-orange-500/5 prose-code:px-1 prose-code:rounded
      prose-pre:border prose-pre:border-zinc-200 dark:prose-pre:border-zinc-800">
      <Content />
    </article>

    <footer class="mt-20 pt-10 border-t border-zinc-100 dark:border-zinc-900">
        <div class="bg-zinc-50 dark:bg-zinc-900/50 p-8 rounded-[2rem] border border-zinc-200 dark:border-zinc-800">
            <h4 class="text-xl font-black uppercase italic dark:text-white mb-2">Systems Thinking</h4>
            <p class="text-zinc-600 dark:text-zinc-400 text-sm leading-relaxed mb-6">
                Thanks for reading. I write about building local-first AI systems, database architectures, and bridging the gap between academia and production.
            </p>
            <a href={`${base}/blogs`} class="text-orange-500 font-bold text-xs uppercase tracking-widest hover:underline">
                Explore more posts →
            </a>
        </div>
    </footer>
  </main>
</Layout>
---
import Layout from '../../layouts/Layout.astro';
import { featuredProjects } from '../../data/projects';

export async function getStaticPaths() {
  return featuredProjects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title={`${project.title} | Jero Halili`}>
  <main class="pt-32 pb-32 px-4 md:px-10 max-w-[900px] mx-auto">
    <a href={`${base}/projects`} class="text-orange-500 font-bold text-xs uppercase tracking-widest mb-12 inline-block hover:-translate-x-1 transition-transform">
      ← Back to Archive
    </a>

    <header class="mb-16">
      <div class="flex items-center gap-3 mb-6">
        <span class="px-3 py-1 bg-orange-500/10 text-orange-500 border border-orange-500/20 rounded-full font-mono text-[10px] font-bold uppercase tracking-widest">
          {project.details.subtitle}
        </span>
      </div>
      <h1 class="text-5xl md:text-7xl font-black tracking-tighter leading-none dark:text-white mb-8 uppercase italic">
        {project.title}
      </h1>
      <div class="flex flex-wrap gap-2">
        {project.details.tags.map(tag => (
          <span class="px-3 py-1 bg-zinc-100 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-full text-[10px] font-bold uppercase tracking-widest text-zinc-500">{tag}</span>
        ))}
      </div>
    </header>

    <div class="w-full aspect-video bg-zinc-50 dark:bg-zinc-900 rounded-[2rem] border border-zinc-200 dark:border-zinc-800 mb-16 overflow-hidden flex items-center justify-center relative">
      <img src={`${base}${project.details.image}`} alt={project.title} class="w-full h-full object-cover" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
      <div style="display:none;" class="w-full h-full items-center justify-center bg-zinc-50 dark:bg-zinc-900">
        <span class="text-8xl font-black text-zinc-200 dark:text-zinc-800 italic select-none">{project.id}</span>
      </div>
    </div>

    <article class="prose prose-zinc dark:prose-invert max-w-none 
      prose-h3:text-3xl prose-h3:font-black prose-h3:tracking-tighter prose-h3:uppercase prose-h3:mt-12
      prose-p:text-lg prose-p:leading-relaxed prose-p:text-zinc-600 dark:prose-p:text-zinc-400
      prose-li:text-zinc-600 dark:prose-li:text-zinc-400
      prose-strong:text-orange-600 dark:prose-strong:text-orange-500">
      
      <h3>The Challenge</h3>
      <p>{project.details.challenge}</p>

      <h3>The Architecture</h3>
      <ul>{project.details.architecture.map(item => <li>{item}</li>)}</ul>

      <h3>Key Features</h3>
      <ul>{project.details.features.map(item => <li>{item}</li>)}</ul>
    </article>
  </main>
</Layout>
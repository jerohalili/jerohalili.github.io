---
import Navbar from '../components/Navbar.astro';
interface Props { title: string; }
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <title>{title}</title>

        <script is:inline>
            // Critical Theme Script (Prevents White Flash)
            const theme = (() => {
                if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
                    return localStorage.getItem('theme');
                }
                return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
            })();

            document.documentElement.classList[theme === 'dark' ? 'add' : 'remove']('dark');
        </script>
    </head>
    <body class="bg-[#FDFDFD] dark:bg-[#050505] text-zinc-900 dark:text-zinc-100 transition-colors duration-500 antialiased selection:bg-orange-500/30 overflow-x-hidden">
        
        <div 
            id="cursor-blob" 
            class="fixed top-0 left-0 w-[300px] h-[300px] sm:w-[600px] sm:h-[600px] bg-orange-500/20 dark:bg-orange-600/25 rounded-full blur-[80px] sm:blur-[140px] pointer-events-none transition-opacity duration-1000 opacity-0 z-[-1]"
        ></div>
        
        <Navbar />
        <slot />

        <script is:inline>
            let blob;
            let curX = 0, curY = 0, tgX = 0, tgY = 0;
            let animationFrameId;
            
            // Check if the device has a mouse
            const isTouchDevice = window.matchMedia("(pointer: coarse)").matches;

            function initBlob() {
                blob = document.getElementById('cursor-blob');
                
                if (isTouchDevice) {
                    // MOBILE BEHAVIOR: 
                    // Instead of following, place it subtly in the top right and leave it.
                    if (blob) {
                        blob.style.opacity = "0.6";
                        blob.style.transform = `translate3d(50vw, -10vh, 0)`;
                    }
                    return; // Stop the follow logic for mobile
                }

                // DESKTOP BEHAVIOR:
                window.addEventListener('mousemove', (e) => {
                    tgX = e.clientX;
                    tgY = e.clientY;
                    if (blob) blob.style.opacity = "1";
                });
                
                render();
            }

            function render() {
                curX += (tgX - curX) * 0.03; 
                curY += (tgY - curY) * 0.03;
                
                if (blob) {
                    // Use 150 offset for mobile size, 300 for desktop
                    const offset = window.innerWidth < 640 ? 150 : 300;
                    blob.style.transform = `translate3d(${curX - offset}px, ${curY - offset}px, 0)`;
                }
                animationFrameId = requestAnimationFrame(render);
            }

            initBlob();

            document.addEventListener('astro:after-swap', () => {
                cancelAnimationFrame(animationFrameId);
                initBlob();
            });
        </script>
    </body>
</html>
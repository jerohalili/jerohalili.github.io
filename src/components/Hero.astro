---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const stats = [
  { label: 'Projects', val: '12+' },
  { label: 'Happy Clients', val: '100%' },
  { label: 'Followers', val: '2.5k' },
  { label: 'Experience', val: '2yrs+' },
  { label: 'Stack', val: 'MERN' }
];
---

<style>
  .hero-topo-container {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
    display: none;
    align-items: center;
    justify-content: center;
    transform: translateZ(0);
    mask-image: 
      radial-gradient(circle at 40% 50%, black 10%, transparent 70%),
      linear-gradient(to bottom, black 60%, transparent 90%);
    -webkit-mask-image: 
      radial-gradient(circle at 40% 50%, black 10%, transparent 70%),
      linear-gradient(to bottom, black 60%, transparent 90%);
    mask-composite: intersect;
    -webkit-mask-composite: source-in;
  }

  @media (min-width: 1024px) {
    .hero-topo-container {
      display: flex;
    }
  }

  .topo-svg {
    width: 150%;
    height: 150%;
    opacity: 0.35;
    flex-shrink: 0;
    backface-visibility: hidden;
  }

  .topo-shape {
    fill: none;
    stroke: #f97316;
    stroke-width: 2.5;
    vector-effect: non-scaling-stroke;
    stroke-linecap: round;
    stroke-dasharray: 1000; 
    stroke-dashoffset: 1000;
    will-change: transform, stroke-dashoffset, opacity;
    animation: 
      topo-drift 55s ease-in-out infinite alternate,
      pulse-draw 18s ease-in-out infinite;
  }

  @keyframes topo-drift {
    0% { transform: translate(0, 0) rotate(0deg); }
    100% { transform: translate(-50px, 40px) rotate(3deg); }
  }

  @keyframes pulse-draw {
    0%, 10%, 90%, 100% { stroke-dashoffset: 2500; opacity: 0; }
    25%, 75% { stroke-dashoffset: 0; opacity: 0.8; }
  }

  /* Fixed opacity using standard Tailwind increments */
  .glass-card {
    @apply bg-white/95 dark:bg-zinc-900/95 backdrop-blur-xl border border-zinc-200/50 dark:border-zinc-800/50 shadow-2xl transition-all duration-500;
  }

  .glow-border:hover {
    @apply lg:border-orange-500 lg:shadow-orange-500/20;
    box-shadow: 0 0 20px -5px rgba(249, 115, 22, 0.4);
  }

  .animate-stable {
    backface-visibility: hidden;
    -webkit-font-smoothing: subpixel-antialiased;
    will-change: transform;
  }
</style>

<section class="relative w-full pt-32 pb-12 md:pt-40 md:pb-24 px-4 md:px-10 bg-transparent overflow-visible min-h-[85vh] flex flex-col justify-center">
  
  <div class="hero-topo-container">
    <svg class="topo-svg" viewBox="0 0 1000 1000">
      <defs>
        <filter id="organic-warp">
          <feTurbulence type="fractalNoise" baseFrequency="0.007" numOctaves="2" seed="123" result="noise" />
          <feDisplacementMap in="SourceGraphic" in2="noise" scale="220" xChannelSelector="R" yChannelSelector="G" />
        </filter>
      </defs>
      <g filter="url(#organic-warp)">
        {[ {x: 200, y: 400}, {x: 450, y: 300}, {x: 350, y: 700} ].map((pos, peakIndex) => (
          [...Array(3)].map((_, ringIndex) => (
            <ellipse 
              class="topo-shape" cx={pos.x} cy={pos.y} rx={100 + (ringIndex * 120)} ry={80 + (ringIndex * 90)}
              style={`animation-delay: ${(peakIndex + ringIndex) * -4}s;`}
            />
          ))
        ))}
        <path class="topo-shape" d="M -200,500 C 100,200 600,800 1200,500" style="animation-delay: -9s; opacity: 0.5;" />
        <path class="topo-shape" d="M -200,300 Q 400,600 1200,200" style="animation-delay: -15s; opacity: 0.5;" />
      </g>
    </svg>
  </div>

  <div class="max-w-[1400px] mx-auto grid grid-cols-1 lg:grid-cols-12 gap-6 relative z-10 w-full">
    
    <div class="lg:col-span-8 glass-card p-8 md:p-16 rounded-[2.5rem] md:rounded-[3.5rem] flex flex-col justify-center">
        <p class="text-orange-500 font-mono tracking-widest font-bold uppercase text-[10px] md:text-xs mb-4">
          Computer Scientist · Full-Stack Developer · AI Engineer
        </p>
        <h1 class="text-5xl md:text-7xl xl:text-[90px] font-black tracking-tighter leading-[0.9] text-zinc-900 dark:text-white mb-8">
          I BUILD SYSTEMS <br /> THAT <span class="text-orange-500 italic">SCALE & GROW</span>
        </h1>
        <p class="text-zinc-500 dark:text-zinc-300 text-lg md:text-xl max-w-xl leading-relaxed">
          Full-stack developer & AI automation engineer based in Angeles, Philippines.
        </p>
    </div>

    <a href={`${base}/about`} class="lg:col-span-4 glass-card glow-border overflow-hidden relative group min-h-[450px] flex flex-col justify-end rounded-[2.5rem] md:rounded-[3.5rem] block">
        <div class="absolute inset-0 z-0">
          <img src={`${base}/images/jero-portrait.png`} alt="Jero Halili" class="w-full h-full object-cover object-top transition-transform duration-1000 group-hover:scale-105" />
        </div>
        <div class="absolute inset-0 z-10 bg-gradient-to-b from-transparent via-transparent to-white dark:to-zinc-950 pointer-events-none"></div>
        <div class="relative z-20 w-full p-6">
          <div class="bg-white/80 dark:bg-zinc-900/80 backdrop-blur-xl border border-white/20 dark:border-zinc-700/30 p-5 rounded-[1.5rem] md:rounded-[2rem] shadow-2xl transition-all duration-500 group-hover:-translate-y-2">
              <div class="space-y-3">
                <div class="flex justify-between items-center">
                    <p class="text-[10px] uppercase tracking-[0.2em] font-black text-orange-500">View Bio</p>
                    <div class="bg-orange-500 p-1.5 rounded-full shadow-lg">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3"><path d="M7 7l10 10M17 7H7v10"/></svg>
                    </div>
                </div>
                <h3 class="text-lg md:text-xl font-bold tracking-tight text-zinc-900 dark:text-white leading-tight">Turning workflows <span class="italic font-medium text-orange-600">into code.</span></h3>
                <div class="flex items-center gap-2 border-t border-zinc-200/50 dark:border-zinc-700/50 pt-3">
                    <span class="w-1.5 h-1.5 rounded-full bg-orange-500 animate-pulse"></span>
                    <p class="text-xs font-medium text-zinc-700 dark:text-zinc-300">MERN Stack · AI Orchestration</p>
                </div>
              </div>
          </div>
        </div>
    </a>

    <div class="lg:col-span-12 grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 mt-6">
        {stats.map((stat) => (
        <div class="glass-card glow-border p-6 rounded-[1.5rem] flex flex-col justify-center items-center text-center group">
            <p class="text-[10px] uppercase tracking-widest font-bold text-zinc-400 mb-1 group-hover:text-orange-500/70 transition-colors">{stat.label}</p>
            <p class="text-2xl font-black text-zinc-900 dark:text-white group-hover:text-orange-500 transition-colors">{stat.val}</p>
        </div>
        ))}
        
        <a href={`${base}/blogs`} class="animate-stable bg-orange-500 p-6 rounded-[1.5rem] flex flex-col justify-center items-center text-center group hover:bg-zinc-900 dark:hover:bg-white transition-all duration-500 ease-out hover:scale-[1.05] active:scale-95 shadow-lg shadow-orange-500/20">
          <p class="text-[10px] uppercase tracking-widest font-bold text-white group-hover:text-zinc-400 dark:group-hover:text-zinc-500 transition-colors">My Blog</p>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-white group-hover:text-orange-500 mt-1 transition-all duration-500 group-hover:translate-x-0.5 group-hover:-translate-y-0.5">
              <path d="M7 17l10-10M17 17V7H7"/>
          </svg>
        </a>
    </div>
  </div>
</section>
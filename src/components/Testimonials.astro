---
import { testimonials } from '../data/testimonials';
---

<section id="testimonials" class="w-full px-4 md:px-10 py-24 transition-colors duration-500 overflow-hidden relative">
  <div class="max-w-[1400px] mx-auto relative z-10">
    
    <div class="flex justify-between items-end mb-12 border-b border-zinc-200 dark:border-zinc-800 pb-8">
      <div class="space-y-2">
        <h2 class="text-4xl md:text-5xl font-black tracking-tighter dark:text-white uppercase italic">Client Voice</h2>
        <p class="text-zinc-700 dark:text-zinc-300 text-sm font-medium">Real feedback from automated workflows and digital systems.</p>
      </div>
      
      <div class="flex gap-2">
        <button id="prev-test" class="p-4 rounded-full border border-zinc-200 dark:border-zinc-800 hover:bg-orange-500 hover:border-orange-500 hover:text-white transition-all dark:text-white group bg-white dark:bg-zinc-900" aria-label="Previous">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        </button>
        <button id="next-test" class="p-4 rounded-full border border-zinc-200 dark:border-zinc-800 hover:bg-orange-500 hover:border-orange-500 hover:text-white transition-all dark:text-white group bg-white dark:bg-zinc-900" aria-label="Next">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
        </button>
      </div>
    </div>

    <div class="relative w-full overflow-hidden">
      <div id="testimonial-slider" class="flex gap-6 will-change-transform">
        {testimonials.map((t) => (
          <div class="testimonial-card min-w-full md:min-w-[calc(50%-12px)] lg:min-w-[calc(33.333%-16px)] bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 p-8 md:p-10 rounded-[2.5rem] flex flex-col justify-between group hover:border-orange-500/50 transition-all shadow-sm">
            <div>
              <div class="text-orange-500 mb-6">
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="currentColor" class="opacity-20 group-hover:opacity-40 transition-opacity"><path d="M14.017 21L14.017 18C14.017 16.8954 14.9124 16 16.017 16H19.017C19.5693 16 20.017 15.5523 20.017 15V9C20.017 8.44772 19.5693 8 19.017 8H16.017C15.4647 8 15.017 8.44772 15.017 9V12C15.017 12.5523 14.5693 13 14.017 13H13.017V21H14.017ZM6.017 21L6.017 18C6.017 16.8954 6.91243 16 8.017 16H11.017C11.5693 16 12.017 15.5523 12.017 15V9C12.017 8.44772 11.5693 8 11.017 8H8.017C7.46472 8 7.017 8.44772 7.017 9V12C7.017 12.5523 6.5693 13 6.017 13H5.017V21H6.017Z"/></svg>
              </div>
              <p class="text-zinc-600 dark:text-zinc-300 text-lg italic leading-relaxed mb-8">"{t.quote}"</p>
            </div>
            
            <div class="flex items-center gap-4 border-t border-zinc-100 dark:border-zinc-800 pt-6">
              <div class="w-12 h-12 rounded-full bg-orange-500 text-white flex items-center justify-center font-black text-xl shadow-lg shadow-orange-500/10">
                {t.author[0]}
              </div>
              <div>
                <h4 class="font-bold text-zinc-900 dark:text-white leading-none">{t.author}</h4>
                <p class="text-xs text-orange-500 font-mono mt-1 uppercase tracking-tighter font-bold">{t.role}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  function initCarousel() {
    const slider = document.getElementById('testimonial-slider');
    const prevBtn = document.getElementById('prev-test');
    const nextBtn = document.getElementById('next-test');

    if (!slider || !slider.parentElement || !prevBtn || !nextBtn) return;

    // 1. Get original cards and clone them
    // We clear existing clones first to prevent stacking on Astro refreshes
    const originalCards = Array.from(slider.children).filter(child => !child.classList.contains('is-clone'));
    const cardCount = originalCards.length;
    if (cardCount === 0) return;

    slider.innerHTML = ''; // Clear and rebuild
    
    // Create 3 sets: [Clones] [Originals] [Clones]
    const allCards = [...originalCards, ...originalCards, ...originalCards];
    allCards.forEach((card, i) => {
      const newCard = card.cloneNode(true) as HTMLElement;
      if (i < cardCount || i >= cardCount * 2) {
        newCard.classList.add('is-clone');
      }
      slider.appendChild(newCard);
    });

    let index = cardCount;
    
    const updateSlider = (smooth = true) => {
      const parentWidth = (slider.parentElement as HTMLElement).offsetWidth;
      const visible = window.innerWidth >= 1024 ? 3 : window.innerWidth >= 768 ? 2 : 1;
      const gap = 24; 
      const cardWidth = (parentWidth - (gap * (visible - 1))) / visible;
      
      slider.style.transition = smooth ? 'transform 300ms ease-out' : 'none';
      slider.style.transform = `translateX(-${index * (cardWidth + gap)}px)`;
    };

    // 2. The Loop Guard
    // This checks if we are out of bounds and snaps back INSTANTLY
    const checkBounds = () => {
      if (index >= cardCount * 2) {
        index = cardCount;
        updateSlider(false);
      } else if (index <= 0) {
        index = cardCount;
        updateSlider(false);
      }
    };

    nextBtn.onclick = () => { 
      index++;
      updateSlider(true);
      
      // If we hit the end of the clones, snap back to center after a tiny delay
      // so the user doesn't see the "empty" space
      if (index >= cardCount * 2) {
        setTimeout(() => {
          index = cardCount;
          updateSlider(false);
        }, 300); // matches the 300ms transition
      }
    };

    prevBtn.onclick = () => { 
      index--;
      updateSlider(true);

      if (index <= 0) {
        setTimeout(() => {
          index = cardCount;
          updateSlider(false);
        }, 300);
      }
    };

    // 3. Fallback for the snap
    slider.addEventListener('transitionend', checkBounds);

    window.addEventListener('resize', () => updateSlider(false));
    updateSlider(false);
  }

  initCarousel();
  document.addEventListener('astro:after-swap', initCarousel);
</script>
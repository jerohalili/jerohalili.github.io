---
import { featuredProjects } from '../data/projects';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const flagship = featuredProjects.find(p => p.isFlagship);
const secondaries = featuredProjects.filter(p => !p.isFlagship);
---

<section id="projects" class="w-full px-4 md:px-10 py-12">
  <div class="max-w-[1400px] mx-auto space-y-8">
    
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end border-b border-zinc-100 dark:border-zinc-800 pb-8 gap-6">
      <div class="space-y-1">
        <h2 class="text-4xl md:text-5xl font-black tracking-tighter dark:text-white uppercase italic">Featured Projects</h2>
        <p class="text-zinc-700 dark:text-zinc-300 text-sm font-medium">Engineered solutions for marketing, education, and creative industries.</p>
      </div>
      
      <a 
        href={`${base}/projects`} 
        class="bg-orange-500 px-8 py-5 rounded-[1.5rem] flex items-center gap-4 group hover:bg-zinc-900 dark:hover:bg-white transition-all duration-500 ease-out hover:scale-[1.05] active:scale-95 shadow-lg shadow-orange-500/20"
      >
        <div class="flex flex-col items-start">
          <p class="text-[10px] uppercase tracking-widest font-bold text-white group-hover:text-white dark:group-hover:text-orange-500 transition-colors">
            All Projects
          </p>
        </div>
        
        <svg 
          xmlns="http://www.w3.org/2000/svg" 
          width="22" height="22" 
          viewBox="0 0 24 24" 
          fill="none" 
          stroke="currentColor" 
          stroke-width="3" 
          class="text-white group-hover:text-white dark:group-hover:text-orange-500 transition-all duration-500 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
        >
          <path d="M7 17l10-10M17 17V7H7"/>
        </svg>
      </a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      {flagship && (
        <div class="bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-[2.5rem] p-8 md:p-10 flex flex-col justify-between group hover:border-orange-500/50 transition-all duration-500 min-h-[700px]">
          <div class="space-y-4">
            <span class="px-3 py-1 bg-orange-500/10 text-orange-500 rounded-full font-mono text-[10px] font-bold uppercase tracking-widest border border-orange-500/20">{flagship.tag}</span>
            <h3 class="text-5xl md:text-6xl font-black tracking-tighter dark:text-white leading-[0.9] uppercase italic">{flagship.title}</h3>
            <p class="text-zinc-700 dark:text-zinc-300 text-lg leading-relaxed max-w-md">{flagship.description}</p>
          </div>
          
          <div class="relative mt-8 bg-zinc-50 dark:bg-zinc-800/50 rounded-[2rem] flex-1 flex items-center justify-center overflow-hidden border border-zinc-100 dark:border-zinc-800">
             <span class="text-9xl font-black text-zinc-200 dark:text-zinc-700/10 italic uppercase tracking-tighter group-hover:scale-110 transition-transform duration-700">{flagship.id}</span>
          </div>
          
          <div class="pt-6">
            <a href={`${base}/projects/${flagship.slug}`} class="inline-flex items-center gap-4 bg-zinc-900 dark:bg-zinc-100 text-white dark:text-black hover:bg-orange-500 hover:text-white px-8 py-4 rounded-full text-xs font-black uppercase tracking-widest transition-all shadow-lg active:scale-95">
              View Architecture
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      )}

      <div class="flex flex-col gap-6">
        {secondaries.map((project) => (
          <div class="flex-1 bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-[2.5rem] p-8 md:p-10 flex flex-col justify-center group hover:border-orange-500/50 transition-all duration-300">
            <div class="flex flex-col md:flex-row items-center gap-8">
              <div class="relative w-full md:w-44 bg-zinc-50 dark:bg-zinc-800/50 rounded-[1.5rem] aspect-square flex items-center justify-center shrink-0 border border-zinc-100 dark:border-zinc-800 overflow-hidden">
                <span class="text-6xl font-black italic text-zinc-200 dark:text-zinc-700/20 group-hover:scale-110 transition-transform duration-500">{project.id}</span>
              </div>
              
              <div class="flex flex-col justify-center space-y-4">
                <div>
                  <span class="text-orange-500 font-mono text-[10px] font-bold uppercase tracking-widest">{project.tag}</span>
                  <h3 class="text-3xl font-black tracking-tighter dark:text-white leading-tight mt-1 uppercase italic">{project.title}</h3>
                </div>
                <p class="text-zinc-700 dark:text-zinc-300 text-base leading-relaxed">{project.description}</p>
                <div>
                  <a href={`${base}/projects/${project.slug}`} class="inline-flex items-center gap-3 bg-zinc-900 dark:bg-zinc-100 text-white dark:text-black hover:bg-orange-500 hover:text-white transition-all px-6 py-3 rounded-full text-xs font-black tracking-widest active:scale-95 uppercase">
                    View Project
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
                  </a>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
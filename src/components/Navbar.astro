---
import ThemeIcon from './ThemeIcon.astro';
import MobileMenu from './MobileMenu.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const navLinks = [
  { name: 'Projects', href: `${base}/projects` },
  { name: 'Services', href: `${base}/#services` },
  { name: 'Testimonials', href: `${base}/#testimonials` },
  { name: 'About', href: `${base}/about` },
  { name: 'Blogs', href: `${base}/blogs` },
];
---

<header class="fixed top-0 left-0 w-full pt-6 px-4 md:px-10 flex justify-center z-[9999] pointer-events-none">
  <nav class="max-w-[1400px] w-full flex justify-between items-center bg-white/70 dark:bg-zinc-900/80 backdrop-blur-xl border border-zinc-200/50 dark:border-zinc-800/50 p-2 md:p-3 rounded-2xl md:rounded-full pointer-events-auto shadow-2xl relative">
    
    <a href={`${base}/`} class="pl-4 font-black text-xl tracking-tighter dark:text-white">
      JERO<span class="text-orange-500">HALILI</span>
    </a>

    <div class="hidden lg:flex items-center gap-1">
      {navLinks.map((link) => (
        <a href={link.href} class="px-5 py-2 rounded-full text-sm font-medium text-zinc-700 dark:text-zinc-300 hover:bg-zinc-100 dark:hover:bg-zinc-800 hover:text-orange-500 transition-all">
          {link.name}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-3 pr-2">
      <button id="mobile-trigger" type="button" class="lg:hidden w-10 h-10 rounded-full bg-zinc-100 dark:bg-zinc-800 flex items-center justify-center border border-zinc-200 dark:border-zinc-700 dark:text-white pointer-events-auto">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="pointer-events-none"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
      </button>

      <ThemeIcon />
      
      <a href={`${base}/contact`} class="hidden sm:block bg-orange-500 text-white px-6 py-2.5 rounded-full text-sm font-bold hover:scale-105 transition-transform">
        Let's Talk
      </a>
    </div>
  </nav>
</header>

<MobileMenu links={navLinks} />

<script is:inline>
  function setupNavbar() {
    const trigger = document.getElementById('mobile-trigger');
    if (trigger) {
      trigger.onclick = () => document.dispatchEvent(new CustomEvent('open-menu'));
    }
  }
  setupNavbar();
  document.addEventListener('astro:after-swap', setupNavbar);
</script>
---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section id="contact" class="w-full px-4 md:px-10 py-24 bg-zinc-900 dark:bg-black text-white rounded-t-[3rem] md:rounded-t-[5rem]">
  <div class="max-w-[1400px] mx-auto text-center space-y-12">
    <div class="space-y-4">
      <h2 class="text-5xl md:text-8xl font-black tracking-tighter uppercase">Let's build <br/> <span class="text-orange-500">Something Big</span></h2>
      <p class="text-zinc-400 text-lg max-w-xl mx-auto italic">Currently available for specialized MERN systems or AI automation consulting.</p>
    </div>
    
    <div class="flex flex-col md:flex-row justify-center gap-6 pt-12">
      <a href="mailto:hello@jerohalili.com" class="bg-orange-500 text-white px-10 py-6 rounded-full text-sm font-black uppercase tracking-[0.2em] hover:scale-105 transition-transform shadow-2xl shadow-orange-500/20">Send an Email</a>
      <a href={`${base}/contact`} class="bg-zinc-800 text-white px-10 py-6 rounded-full text-sm font-black uppercase tracking-[0.2em] border border-zinc-700 hover:bg-white hover:text-black transition-all">Let's Talk</a>
    </div>

    <div class="pt-12 flex flex-col md:flex-row justify-between items-center border-t border-zinc-800 gap-8">
      <p class="font-mono text-xs text-zinc-500 uppercase">© 2026 Jero Halili · Built with Astro & Tailwind</p>
      <div class="flex gap-8">
        {['GitHub', 'LinkedIn', 'X (Twitter)'].map(link => (
          <a href="#" class="text-xs font-black uppercase tracking-widest hover:text-orange-500 transition-colors">{link}</a>
        ))}
      </div>
    </div>
  </div>
</section>
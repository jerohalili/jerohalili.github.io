---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const socialLinks = [
  { name: 'GitHub', url: 'https://github.com/jerohalili' },
  { name: 'LinkedIn', url: 'https://www.linkedin.com/in/jero-halili-bb385b295' }, 
];
---

<section id="contact" class="w-full px-4 md:px-10 py-24 bg-zinc-900 dark:bg-black text-white rounded-t-[3rem] md:rounded-t-[5rem]">
  <div class="max-w-[1400px] mx-auto text-center space-y-12">
    <div class="space-y-4">
      <h2 class="text-5xl md:text-8xl font-black tracking-tighter uppercase">Let's build <br/> <span class="text-orange-500">Something Big</span></h2>
      <p class="text-zinc-400 text-lg max-w-xl mx-auto italic">Currently available for specialized MERN systems or AI automation consulting.</p>
    </div>
    
    <div class="flex flex-col md:flex-row justify-center items-center gap-4 pt-8">
      <a 
        href="mailto:hello@jerohalili.com" 
        class="group w-full md:w-auto bg-orange-500 text-white px-8 py-4 rounded-full text-[11px] font-black uppercase tracking-[0.2em] transition-all duration-500 ease-out hover:bg-white hover:text-black hover:scale-[1.05] active:scale-95 shadow-xl shadow-orange-500/10 flex items-center justify-center gap-3"
      >
        Send an Email
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="group-hover:rotate-12 transition-transform duration-500">
          <path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/>
        </svg>
      </a>

      <a 
        href={`${base}/contact`} 
        class="group w-full md:w-auto bg-zinc-800 text-white px-8 py-4 rounded-full text-[11px] font-black uppercase tracking-[0.2em] border border-zinc-700 transition-all duration-500 ease-out hover:bg-white hover:text-black hover:border-white hover:scale-[1.05] active:scale-95 flex items-center justify-center gap-3"
      >
        Let's Talk
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="group-hover:translate-x-1 transition-transform duration-500">
          <path d="M5 12h14m-7-7 7 7-7 7"/>
        </svg>
      </a>
    </div>

    <div class="pt-12 flex flex-col md:flex-row justify-between items-center border-t border-zinc-800 gap-8">
      <p class="font-mono text-[10px] text-zinc-500 uppercase">© 2026 Jero Halili · Built with Astro & Tailwind</p>
      <div class="flex gap-8">
        {socialLinks.map(link => (
          <a 
            href={link.url} 
            target="_blank" 
            rel="noopener noreferrer" 
            class="text-[10px] font-black uppercase tracking-widest hover:text-orange-500 transition-colors"
          >
            {link.name}
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
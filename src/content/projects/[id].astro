---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project: CollectionEntry<'projects'>) => ({
    params: { id: project.id }, 
    props: { project },
  }));
}

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { Content } = await render(project);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title={`${project.data.title} | Jero Halili`}>
  <main class="pt-32 pb-32 px-4 md:px-10 max-w-[900px] mx-auto">
    <a href={`${base}/#works`} class="text-orange-500 font-bold text-xs uppercase mb-12 inline-block">← Back to Systems</a>
    
    <header class="mb-16">
      <span class="px-3 py-1 bg-orange-500/10 text-orange-500 rounded-full font-mono text-[10px] font-bold uppercase">{project.data.subtitle}</span>
      <h1 class="text-5xl md:text-7xl font-black tracking-tighter dark:text-white mt-6">{project.data.title}</h1>
      <div class="flex flex-wrap gap-2 mt-6">
        {project.data.tags.map((tag: string) => (
          <span class="px-3 py-1 bg-zinc-100 dark:bg-zinc-900 border border-zinc-800 rounded-full text-[10px] font-bold text-zinc-500">{tag}</span>
        ))}
      </div>
    </header>

    <article class="prose prose-zinc dark:prose-invert max-w-none">
      <Content />
    </article>
  </main>
</Layout>